{
  "preset": "ts-jest",
  "testEnvironment": "jsdom",
  "moduleNameMapper": {
    "\\.(css|less|scss|sass)$": "identity-obj-proxy"
  },
  "transform": {
    "^.+\\.(ts|tsx)$": [
      "ts-jest",
      {
        "tsconfig": {
          "jsx": "react-jsx"
        }
      }
    ]
  },
  "testMatch": ["**/__tests__/**/*.test.{ts,tsx}", "**/tests/**/*.test.{ts,tsx}"]
}
